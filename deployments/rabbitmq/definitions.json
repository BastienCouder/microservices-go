{
  "users": [
    {
      "name": "app",
      "password": "app",
      "tags": "management"
    }
  ],
  "vhosts": [
    {"name": "/"}
  ],
  "permissions": [
    {
      "user": "app",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "microservices.events",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "project.finalize",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "notification.email.send",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "microservices.events",
      "vhost": "/",
      "destination": "project.finalize",
      "destination_type": "queue",
      "routing_key": "project.finalized",
      "arguments": {}
    },
    {
      "source": "microservices.events",
      "vhost": "/",
      "destination": "notification.email.send",
      "destination_type": "queue",
      "routing_key": "notification.email.requested",
      "arguments": {}
    }
  ]
}
